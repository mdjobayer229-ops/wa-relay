# Cloudflare app URL (required) — your main app webhook endpoint
APP_URL=https://career.jobayergroup.com

# WhatsApp phone number (for your reference only)
WHATSAPP_PHONE=880130585531

# Port (Railway sets this automatically)
PORT=8080

# Auth token for secure endpoints (/reset, /stop, /start, /backup-auth)
# Set a strong random string in Railway dashboard
AUTH_TOKEN=your-secret-auth-token

# Account ID for the message queue
WA_ACCOUNT_ID=web_main

# Base64-encoded auth backup (set after first QR scan via /backup-auth endpoint)
# AUTH_BASE64=
